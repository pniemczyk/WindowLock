<?xml version="1.0" encoding="UTF-8"?>
<installer-gui-script minSpecVersion="2">
  <title>WindowLock</title>
  <welcome file="welcome.html" />
  <readme file="readme.html" />
  <license file="license.html" />
  <conclusion file="conclusion.html" />

  <options
    customize="never"
    require-scripts="false"
    rootVolumeOnly="true"
    hostArchitectures="arm64,x86_64" />

  <volume-check>
    <allowed-os-versions>
      <os-version min="13.0" />
    </allowed-os-versions>
  </volume-check>

  <choices-outline>
    <line choice="default">
      <line choice="com.way2do.windowlock" />
    </line>
  </choices-outline>

  <choice id="default" />

  <choice id="com.way2do.windowlock"
    visible="false"
    selected="true"
    enabled="true">
    <pkg-ref id="com.way2do.windowlock" />
  </choice>

  <pkg-ref id="com.way2do.windowlock"
    version="1.1.0"
    onConclusion="launch">WindowLock-component.pkg</pkg-ref>
</installer-gui-script>
